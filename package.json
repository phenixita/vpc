{
  "name": "vpc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n functions,web -c magenta,cyan \"npm run dev:functions\" \"vite\"",
    "dev:functions": "firebase emulators:start --only functions --project demo-vpc",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "npm run build && firebase emulators:start --only hosting,functions --project demo-vpc",
    "start": "npm run preview",
    "deploy": "firebase deploy --only hosting,functions",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-tools": "^15.16.0",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
