{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/analyze-curve",
        "function": "analyzeCurve"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
